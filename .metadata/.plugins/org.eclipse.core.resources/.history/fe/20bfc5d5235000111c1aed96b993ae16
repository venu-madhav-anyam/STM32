TaskHandle_t xTaskHandle1;
TaskHandle_t xTaskHandle2;

SemaphoreHandle_t xCountingSemaphore;

UART_HandleTypeDef huart2;

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
void vtask_handler1(void *parameters);
void vtask_handler2(void *parameters);

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
	BaseType_t xHigherPriorityTaskWoken = pdFALSE;

	if (GPIO_Pin == GPIO_PIN_13) {
		xSemaphoreGiveFromISR(xCountingSemaphore, &xHigherPriorityTaskWoken);

		portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
	}
}

void printmsg(char *msg) {
	HAL_UART_Transmit(&huart2, (uint8_t*) msg, strlen(msg), HAL_MAX_DELAY);
}

int main(void) {
	HAL_Init();

	SystemClock_Config();

	MX_GPIO_Init();
	MX_USART2_UART_Init();

	xCountingSemaphore =
	    xSemaphoreCreateCounting(
	            10,
	            0);

	if (xCountingSemaphore != NULL) {
		xTaskCreate(vtask_handler1, "Task-1", 500, NULL, 3, NULL);
		//xTaskCreate(vtask_handler2, "Task-2", 250, NULL, 1, NULL);

		vTaskStartScheduler();
	}

	while (1) {
	}
}

void vtask_handler1(void *parameters) {

	char msg[50];

	uint32_t count = 0;

	while (1) {

		if (xSemaphoreTake(xCountingSemaphore,
				portMAX_DELAY) == pdTRUE) {
			count++;
			sprintf(msg, "Button Press Count = %lu\r\n", count);
			printmsg(msg);
		}
	}
}

