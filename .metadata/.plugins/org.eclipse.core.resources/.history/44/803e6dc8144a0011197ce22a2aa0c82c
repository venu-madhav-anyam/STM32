#include "opt3001.h"

/* ===================== LOCAL HELPERS ====================== */

static uint8_t OPT3001_WaitFlag(I2C_Handle_t *pI2CHandle, uint32_t flag) {
	uint32_t timeout = 100000;

	while (!(pI2CHandle->pI2Cx->ISR & flag)) {
		if (--timeout == 0)
			return 0;
	}

	return 1;
}

/* ===================== WRITE REGISTER ===================  */

void OPT3001_WriteReg(I2C_Handle_t *pI2CHandle, uint8_t reg, uint16_t value) {
	uint8_t data[3];

	data[0] = reg;
	data[1] = (value >> 8) & 0xFF;
	data[2] = value & 0xFF;

	I2C_MasterSendData(pI2CHandle, data, 3,
	OPT3001_ADDR);
}

/* ====================== READ REGISTER ===================== */

uint16_t OPT3001_ReadReg(I2C_Handle_t *pI2CHandle, uint8_t reg) {
	uint8_t rx[2];

	/* Clear flags */
	pI2CHandle->pI2Cx->ICR |=
	I2C_ICR_STOPCF |
	I2C_ICR_NACKCF;

	/* ================= WRITE REGISTER ADDRESS ============== */

	pI2CHandle->pI2Cx->CR2 = 0;

	pI2CHandle->pI2Cx->CR2 |= (OPT3001_ADDR << 1);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_NBYTES_Pos);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

	if (!OPT3001_WaitFlag(pI2CHandle,
	I2C_ISR_TXIS)) {
		return 0xFFFF;
	}

	pI2CHandle->pI2Cx->TXDR = reg;

	if (!OPT3001_WaitFlag(pI2CHandle,
	I2C_ISR_TC)) {
		return 0xFFFF;
	}

	/* ================= REPEATED START READ ================= */

	pI2CHandle->pI2Cx->CR2 = 0;

	pI2CHandle->pI2Cx->CR2 |= (OPT3001_ADDR << 1);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_RD_WRN_Pos);

	pI2CHandle->pI2Cx->CR2 |= (2 << I2C_CR2_NBYTES_Pos);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_AUTOEND_Pos);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

	/* Read MSB */
	if (!OPT3001_WaitFlag(pI2CHandle,
	I2C_ISR_RXNE)) {
		return 0xFFFF;
	}

	rx[0] = pI2CHandle->pI2Cx->RXDR;

	/* Read LSB */
	if (!OPT3001_WaitFlag(pI2CHandle,
	I2C_ISR_RXNE)) {
		return 0xFFFF;
	}

	rx[1] = pI2CHandle->pI2Cx->RXDR;

	/* Wait STOP */
	if (!OPT3001_WaitFlag(pI2CHandle,
	I2C_ISR_STOPF)) {
		return 0xFFFF;
	}

	/* Clear STOP */
	pI2CHandle->pI2Cx->ICR |=
	I2C_ICR_STOPCF;

	return ((rx[0] << 8) | rx[1]);
}

/* ======================= SENSOR INIT ======================= */

void OPT3001_Init(I2C_Handle_t *pI2CHandle) {
	/*
	 * 0xC410
	 *
	 * Continuous conversions
	 * Automatic full-scale
	 * 800ms conversion time
	 */

	OPT3001_WriteReg(pI2CHandle,
	OPT3001_REG_CONFIG, 0xC410);
}

/* ======================== READ LUX ========================= */

int OPT3001_ReadLux(I2C_Handle_t *pI2CHandle) {
	uint16_t raw;
	uint16_t exponent;
	uint16_t mantissa;

	raw = OPT3001_ReadReg(pI2CHandle,
	OPT3001_REG_RESULT);

	exponent = (raw >> 12) & 0x0F;

	mantissa = raw & 0x0FFF;

	/*
	 * Lux = mantissa * 0.01 * 2^exponent
	 *
	 * Integer approximation
	 */

	return ((mantissa << exponent) / 100);
}
