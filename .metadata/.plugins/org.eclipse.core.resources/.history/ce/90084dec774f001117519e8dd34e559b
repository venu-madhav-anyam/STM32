#include "main.h"
#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include "semphr.h"
#include <stdio.h>

TaskHandle_t xTaskHandle1;
TaskHandle_t xTaskHandle2;

xSemaphoreHandle xwork;

xQueueHandle xworkqueue;

UART_HandleTypeDef huart2;

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
void vtask_handler1(void *parameters);
void vtask_handler2(void *parameters);

int main(void) {
	HAL_Init();

	SystemClock_Config();

	MX_GPIO_Init();
	MX_USART2_UART_Init();

	vSemaphoreCreateBinary(xwork);
	xworkqueue = xQueueCreate(1, sizeof(unsigned int));

	printf("UART Working..!");
	if (!xwork && !xworkqueue) {
		xTaskCreate(vtask_handler1, "Task-1", 500, NULL, 3, NULL);
		xTaskCreate(vtask_handler2, "Task-2", 500, NULL, 1, NULL);

		vTaskStartScheduler();
	}

	printf("Creation Failed...!");

	while (1) {
	}
}

void vtask_handler1(void *parameters) {

	unsigned int ticket_id;
	portBASE_TYPE status;

	xSemaphoreGive(xwork);

	while (1) {
		ticket_id = (rand() & 0x1FF);

		status = xQueueSend(xworkqueue, &ticket_id, portMAX_DELAY);

		if (status != pdPASS)
			printf("Msg sending Failed..!");
		else {
			xSemaphoreGive(xwork);
			taskYIELD();
		}
	}
}

void vtask_handler2(void *parameters) {
	unsigned int ticket_id;
	portBASE_TYPE status;

	xSemaphoreTake(xwork, 0);

	while (1) {

		status = xQueueReceive(xworkqueue, &ticket_id, 0);

		if (status != pdPASS) {
			printf("Ticked ID : %d\r\n", ticket_id);
			vTaskDelay(ticket_id);
		} else {
			printf("Queue is Empty..!");
		}
	}
}

