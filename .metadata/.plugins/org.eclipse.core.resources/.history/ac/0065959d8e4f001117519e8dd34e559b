#include "main.h"
#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include "semphr.h"
#include <stdio.h>"
#include <string.h>

UART_HandleTypeDef huart2;

TaskHandle_t xTaskHandle1;
TaskHandle_t xTaskHandle2;

#define TRUE	1
#define FALSE	0

uint8_t UART_KEY = TRUE;
uint32_t num = 1;

QueueHandle_t xQueue;
SemaphoreHandle_t xUartMutex;

void SystemClock_Config(void);
static void MX_USART2_UART_Init(void);
void vtask_handler1(void *parameters);
void vtask_handler2(void *parameters);

int main(void) {
	HAL_Init();

	SystemClock_Config();
	MX_USART2_UART_Init();

	printf("UART active\r\n");
	xQueue = xQueueCreate(5, sizeof(uint32_t));

	if (xQueue != NULL) {
		xTaskCreate(vtask_handler1, "Task-1", 250, NULL, 2,
		NULL);

		xTaskCreate(vtask_handler2, "Task-2", 250, NULL, 2,
		NULL);

		vTaskStartScheduler();
	}

	while (1)
		;
}

void vtask_handler1(void *parameters) {
	uint32_t count = 0;

	while (1) {
		count++;

		xQueueSend(xQueue, &count, portMAX_DELAY);


		HAL_UART_Transmit(&huart2,
		                  (uint8_t*)"Sent\r\n",
		                  6,
		                  HAL_MAX_DELAY);

		vTaskDelay(pdMS_TO_TICKS(1000));
	}
}

void vtask_handler2(void *parameters) {
	uint32_t rx_data;

	while (1) {
		if (xQueueReceive(xQueue, &rx_data,
		portMAX_DELAY) == pdPASS) {

			//printf("Received : %lu\r\n", rx_data);

			char msg[30];

			sprintf(msg, "RX=%lu\r\n", rx_data);

			HAL_UART_Transmit(&huart2,
			                  (uint8_t*)msg,
			                  strlen(msg),
			                  HAL_MAX_DELAY);

		}
	}
}

