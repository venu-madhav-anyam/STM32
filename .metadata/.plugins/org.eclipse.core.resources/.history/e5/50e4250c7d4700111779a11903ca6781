#include "stm32l476xx_gpio.h"

#include "stm32l476xx_gpio.h"

/* -------- CLOCK CONTROL -------- */
/**
 * @brief   Enables or disables the peripheral clock for the given GPIO port
 *
 * @param   pGPIOx        Base address of the GPIO peripheral (GPIOA, GPIOB, ...)
 * @param   En_or_Dis     ENABLE (1) or DISABLE (0)
 *
 * @return  None
 *
 * @note    Clock must be enabled before using any GPIO register
 */
void GPIO_PeriClockControl(GPIO_TypeDef *pGPIOx, uint8_t En_or_Dis) {
	if (En_or_Dis) {
		if (pGPIOx == GPIOA)
			RCC->AHB2ENR |= (1 << 0);
		else if (pGPIOx == GPIOB)
			RCC->AHB2ENR |= (1 << 1);
		else if (pGPIOx == GPIOC)
			RCC->AHB2ENR |= (1 << 2);
		else if (pGPIOx == GPIOD)
			RCC->AHB2ENR |= (1 << 3);
		else if (pGPIOx == GPIOE)
			RCC->AHB2ENR |= (1 << 4);
		else if (pGPIOx == GPIOF)
			RCC->AHB2ENR |= (1 << 5);
		else if (pGPIOx == GPIOG)
			RCC->AHB2ENR |= (1 << 6);
		else if (pGPIOx == GPIOH)
			RCC->AHB2ENR |= (1 << 7);
	}
}

/* -------- INIT -------- */
/**
 * @brief   Initializes the GPIO pin with given configuration
 *
 * @param   pGPIOHandle   Pointer to GPIO handle structure
 *
 * @return  None
 *
 * @note    Configures mode, speed, pull-up/down, output type and alternate function
 */
void GPIO_Init(GPIO_Handle_t *pGPIOHandle) {
	uint32_t temp = 0;

	/* MODE */
	temp = (pGPIOHandle->GPIO_PinConfig.GPIO_PinMode
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->MODER &= ~(3
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->MODER |= temp;

	/* SPEED */
	temp = (pGPIOHandle->GPIO_PinConfig.GPIO_PinSpeed
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->OSPEEDR &= ~(3
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->OSPEEDR |= temp;

	/* PULL-UP / PULL-DOWN */
	temp = (pGPIOHandle->GPIO_PinConfig.GPIO_PinPuPdControl
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->PUPDR &= ~(3
			<< (2 * pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber));
	pGPIOHandle->pGPIOx->PUPDR |= temp;

	/* OUTPUT TYPE */
	temp = (pGPIOHandle->GPIO_PinConfig.GPIO_PinOPType
			<< pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber);
	pGPIOHandle->pGPIOx->OTYPER &= ~(1
			<< pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber);
	pGPIOHandle->pGPIOx->OTYPER |= temp;

	/* ALTERNATE FUNCTION */
	if (pGPIOHandle->GPIO_PinConfig.GPIO_PinMode == 2) // AF mode
			{
		uint8_t pin = pGPIOHandle->GPIO_PinConfig.GPIO_PinNumber;
		uint8_t af = pGPIOHandle->GPIO_PinConfig.GPIO_PinAltFunMode;

		if (pin < 8) {
			pGPIOHandle->pGPIOx->AFRL &= ~(0xF << (4 * pin));
			pGPIOHandle->pGPIOx->AFRL |= (af << (4 * pin));
		} else {
			pGPIOHandle->pGPIOx->AFRH &= ~(0xF << (4 * (pin - 8)));
			pGPIOHandle->pGPIOx->AFRH |= (af << (4 * (pin - 8)));
		}
	}
}

/* -------- DEINIT -------- */
/**
 * @brief   Resets the given GPIO peripheral
 *
 * @param   pGPIOx    Base address of GPIO peripheral
 *
 * @return  None
 *
 * @note    Resets all registers to default values
 */
void GPIO_DeInit(GPIO_TypeDef *pGPIOx) {
	if (pGPIOx == GPIOA)
		RCC->AHB2RSTR |= (1 << 0);
	else if (pGPIOx == GPIOB)
		RCC->AHB2RSTR |= (1 << 1);
	else if (pGPIOx == GPIOC)
		RCC->AHB2RSTR |= (1 << 2);
}

/* -------- READ -------- */
uint8_t GPIO_ReadFromInputPin(GPIO_TypeDef *pGPIOx, uint8_t PinNumber) {
	return (uint8_t) ((pGPIOx->IDR >> PinNumber) & 0x1);
}

uint16_t GPIO_ReadFromInputPort(GPIO_TypeDef *pGPIOx) {
	return (uint16_t) (pGPIOx->IDR);
}

/* -------- WRITE -------- */
void GPIO_WriteToOutputPin(GPIO_TypeDef *pGPIOx, uint8_t PinNumber,
		uint8_t Value) {
	if (Value)
		pGPIOx->BSRR = (1 << PinNumber);
	else
		pGPIOx->BSRR = (1 << (PinNumber + 16));
}

void GPIO_WriteToOutputPort(GPIO_TypeDef *pGPIOx, uint16_t Value) {
	pGPIOx->ODR = Value;
}

void GPIO_ToggleOutputPin(GPIO_TypeDef *pGPIOx, uint8_t PinNumber) {
	pGPIOx->ODR ^= (1 << PinNumber);
}
