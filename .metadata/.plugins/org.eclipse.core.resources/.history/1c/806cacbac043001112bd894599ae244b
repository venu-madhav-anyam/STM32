/* -------- HANDLES -------- */
I2C_HandleTypeDef hi2c2;
UART_HandleTypeDef huart2;
SPI_HandleTypeDef hspi1;

/* -------- OPT3001 (I2C) -------- */
#define OPT3001_ADDR        (0x47 << 1)
#define OPT3001_REG_RESULT  0x00
#define OPT3001_REG_CONFIG  0x01

/* -------- W25Q FLASH (SPI) -------- */
#define FLASH_CS_PORT       GPIOA
#define FLASH_CS_PIN        GPIO_PIN_4
#define W25Q_PAGE_SIZE      256
#define W25Q_SECTOR_SIZE    4096

#define CS_LOW()  HAL_GPIO_WritePin(FLASH_CS_PORT, FLASH_CS_PIN, GPIO_PIN_RESET)
#define CS_HIGH() HAL_GPIO_WritePin(FLASH_CS_PORT, FLASH_CS_PIN, GPIO_PIN_SET)

/* -------- PROTOTYPES -------- */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C2_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_SPI1_Init(void);

/* -------- PRINTF REDIRECT -------- */
int _write(int file, char *ptr, int len) {
    HAL_UART_Transmit(&huart2, (uint8_t*)ptr, len, 100);
    return len;
}

/* -------- OPT3001 FUNCTIONS -------- */
void OPT3001_Init(void) {
    uint8_t config[3] = { OPT3001_REG_CONFIG, 0xC4, 0x10 }; // Continuous conversion
    HAL_I2C_Master_Transmit(&hi2c2, OPT3001_ADDR, config, 3, 100);
}

float OPT3001_ReadLux(void) {
    uint8_t reg = OPT3001_REG_RESULT;
    uint8_t data[2];
    if (HAL_I2C_Master_Transmit(&hi2c2, OPT3001_ADDR, &reg, 1, 100) != HAL_OK) return -1.0f;
    if (HAL_I2C_Master_Receive(&hi2c2, OPT3001_ADDR, data, 2, 100) != HAL_OK) return -1.0f;

    uint16_t raw = (data[0] << 8) | data[1];
    uint16_t exponent = (raw >> 12) & 0x0F;
    uint16_t mantissa = raw & 0x0FFF;
    return 0.01f * (1 << exponent) * mantissa;
}

/* -------- W25Q FLASH FUNCTIONS -------- */
void W25Q_WriteEnable(void) {
    uint8_t cmd = 0x06;
    CS_LOW();
    HAL_SPI_Transmit(&hspi1, &cmd, 1, 100);
    CS_HIGH();
}

void W25Q_WaitBusy(void) {
    uint8_t cmd = 0x05;
    uint8_t status;
    do {
        CS_LOW();
        HAL_SPI_Transmit(&hspi1, &cmd, 1, 100);
        HAL_SPI_Receive(&hspi1, &status, 1, 100);
        CS_HIGH();
    } while (status & 0x01);
}

uint16_t W25Q_ReadID(void) {
    uint8_t cmd[4] = {0x90, 0x00, 0x00, 0x00};
    uint8_t id[2];
    CS_LOW();
    HAL_SPI_Transmit(&hspi1, cmd, 4, 100);
    HAL_SPI_Receive(&hspi1, id, 2, 100);
    CS_HIGH();
    return (id[0] << 8) | id[1];
}

void W25Q_EraseSector(uint32_t addr) {
    uint8_t cmd[4] = { 0x20, (addr >> 16) & 0xFF, (addr >> 8) & 0xFF, addr & 0xFF };
    W25Q_WriteEnable();
    CS_LOW();
    HAL_SPI_Transmit(&hspi1, cmd, 4, 100);
    CS_HIGH();
    W25Q_WaitBusy();
}

void W25Q_Write(uint32_t addr, uint8_t *data, uint16_t len) {
    uint8_t cmd[4] = { 0x02, (addr >> 16) & 0xFF, (addr >> 8) & 0xFF, addr & 0xFF };
    W25Q_WriteEnable();
    CS_LOW();
    HAL_SPI_Transmit(&hspi1, cmd, 4, 100);
    HAL_SPI_Transmit(&hspi1, data, len, 100);
    CS_HIGH();
    W25Q_WaitBusy();
}

void W25Q_Read(uint32_t addr, uint8_t *data, uint16_t len) {
    uint8_t cmd[4] = { 0x03, (addr >> 16) & 0xFF, (addr >> 8) & 0xFF, addr & 0xFF };
    CS_LOW();
    HAL_SPI_Transmit(&hspi1, cmd, 4, 100);
    HAL_SPI_Receive(&hspi1, data, len, 100);
    CS_HIGH();
}

/* -------- MAIN -------- */
int main(void) {
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_USART2_UART_Init();
    MX_I2C2_Init();
    MX_SPI1_Init();

    printf("--- STM32 Data Logger Start ---\r\n");

    // Check Flash connection
    uint16_t devID = W25Q_ReadID();
    printf("Flash ID: 0x%04X\r\n", devID);

    OPT3001_Init();
    W25Q_EraseSector(0);

    uint32_t flash_addr = 0;
#define BUFFER_SIZE 15

float dat_buf[BUFFER_SIZE];
uint8_t write_index = 0;

while (1)
{
    float lux = OPT3001_ReadLux();

    /* -------- WRITE TO RING BUFFER -------- */
    dat_buf[write_index] = lux;

    /* -------- READ BACK (same index) -------- */
    float read_lux = dat_buf[write_index];

    printf("[%02d] Sensor: %.2f Lux | Buffer: %.2f Lux\r\n",
           write_index, lux, read_lux);

    /* -------- MOVE INDEX -------- */
    write_index++;

    /* -------- WRAP AROUND -------- */
    if (write_index >= BUFFER_SIZE)
    {
        write_index = 0;
        printf("Buffer wrapped.\r\n");
    }

    HAL_Delay(1000);
}

