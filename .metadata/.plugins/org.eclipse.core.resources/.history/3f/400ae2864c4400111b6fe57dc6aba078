/* -------- OPT3001 -------- */
static void OPT3001_Write(uint8_t devAddr, uint8_t reg, uint16_t data) {
	uint8_t buf[3];

	buf[0] = reg;
	buf[1] = (data >> 8) & 0xFF;  // MSB
	buf[2] = data & 0xFF;         // LSB

	HAL_I2C_Master_Transmit(&hi2c2, devAddr << 1, buf, 3, HAL_MAX_DELAY);
}

static uint16_t OPT3001_ReadReg(uint8_t devAddr, uint8_t reg) {
	uint8_t data[2];

	HAL_I2C_Master_Transmit(&hi2c2, devAddr << 1, &reg, 1, HAL_MAX_DELAY);
	HAL_I2C_Master_Receive(&hi2c2, devAddr << 1, data, 2, HAL_MAX_DELAY);

	return ((uint16_t) data[0] << 8) | data[1];
}

static void opt3001_init(void) {
	OPT3001_Write(0x47, OPT3001_CONFIG_REG, 0xC410);
}

static float opt3001_read_lux(void) {
	uint16_t raw = OPT3001_ReadReg(0x47, OPT3001_RESULT_REG);

	uint16_t exp = (raw >> 12) & 0x0F;
	uint16_t mant = raw & 0x0FFF;

	return (0.01f * (1 << exp) * mant);
}
/* -------- SPI HELPERS -------- */
void SPI_Write(uint8_t *data, uint16_t size) {
	HAL_SPI_Transmit(&hspi1, data, size, 100);
}

void SPI_Read(uint8_t *data, uint16_t size) {
	HAL_SPI_Receive(&hspi1, data, size, 100);
}

/* -------- FLASH -------- */
void W25Q_WriteEnable(void) {
	uint8_t cmd = 0x06;

	CS_LOW();
	HAL_SPI_Transmit(&hspi1, &cmd, 1, 100);
	CS_HIGH();
}

uint8_t W25Q_ReadStatus(void) {
	uint8_t tx[2] = { 0x05, 0xFF };
	uint8_t rx[2];

	CS_LOW();
	HAL_SPI_TransmitReceive(&hspi1, tx, rx, 2, 100);
	CS_HIGH();

	return rx[1];   // ⭐ correct byte
}

void W25Q_WaitBusy(void) {
	while (W25Q_ReadStatus() & 0x01)
		;
}

void W25Q_EraseSector(uint32_t addr) {
	uint8_t cmd[4];
	W25Q_WriteEnable();

	cmd[0] = 0x20;
	cmd[1] = addr >> 16;
	cmd[2] = addr >> 8;
	cmd[3] = addr;

	CS_LOW();
	SPI_Write(cmd, 4);
	CS_HIGH();

	W25Q_WaitBusy();
}

void W25Q_Write(uint32_t addr, uint8_t *data, uint16_t len) {
	W25Q_WriteEnable();

	uint8_t cmd[4];
	cmd[0] = 0x02;
	cmd[1] = addr >> 16;
	cmd[2] = addr >> 8;
	cmd[3] = addr;

	CS_LOW();

	HAL_SPI_Transmit(&hspi1, cmd, 4, 100);
	HAL_SPI_Transmit(&hspi1, data, len, 100);

	CS_HIGH();

	W25Q_WaitBusy();
}

void W25Q_Read(uint32_t addr, uint8_t *data, uint16_t len) {
	uint8_t tx[4 + len];
	uint8_t rx[4 + len];

	tx[0] = 0x03;
	tx[1] = (addr >> 16) & 0xFF;
	tx[2] = (addr >> 8) & 0xFF;
	tx[3] = addr & 0xFF;

	memset(&tx[4], 0xFF, len);

	CS_LOW();
	HAL_SPI_TransmitReceive(&hspi1, tx, rx, 4 + len, HAL_MAX_DELAY);
	CS_HIGH();

	memcpy(data, &rx[4], len);
}

/* -------- BUTTON -------- */
uint8_t print_logs;
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
	if (GPIO_Pin == GPIO_PIN_13) {
		printf("Button Pressed!\r\n");
		print_logs = 1;
	}
}

void EXTI15_10_IRQHandler(void) {
	HAL_GPIO_EXTI_IRQHandler(GPIO_PIN_13);
}

/* -------- Log Variables -------- */
#define LOG_SIZE 4
#define MAX_LOGS 5

uint32_t logCounter = 0;

/* -------- MAIN -------- */
int main(void) {
	HAL_Init();
	SystemClock_Config();

	MX_GPIO_Init();
	MX_I2C2_Init();
	MX_USART2_UART_Init();
	MX_SPI1_Init();

	opt3001_init();
	HAL_Delay(800);

	W25Q_EraseSector(0x000000);

	while (1) {
		float lux = opt3001_read_lux();
		printf("Lux = %.2f\r\n", lux);

		uint8_t buffer[4];
		memcpy(buffer, &lux, 4);

		/* -------- WRITE (CIRCULAR) -------- */
		uint32_t addr = (logCounter % MAX_LOGS) * LOG_SIZE;
		W25Q_Write(addr, buffer, 4);

		logCounter++;

		/* -------- PRINT LAST LOGS -------- */
		if (print_logs) {
			printf("---- LOGS ----\r\n");

			uint32_t count = (logCounter < MAX_LOGS) ? logCounter : MAX_LOGS;

			for (uint32_t i = 0; i < count; i++) {
				uint32_t index = (logCounter - count + i) % MAX_LOGS;
				uint32_t read_addr = index * LOG_SIZE;

				uint8_t read_buf[4];
				float lux_read;

				W25Q_Read(read_addr, read_buf, 4);
				memcpy(&lux_read, read_buf, 4);

				printf("[%d] = %.2f\r\n", i, lux_read);
			}

			printf("----------------\r\n");
		}

		HAL_Delay(1000);
	}
}

