void USART2_GPIO_Init(void) {
	GPIO_Handle_t USARTPins;

	USARTPins.pGPIOx = GPIOA;

	USARTPins.GPIO_PinConfig.GPIO_PinMode =
	GPIO_MODE_ALTFN;

	USARTPins.GPIO_PinConfig.GPIO_PinAltFunMode = 7;

	USARTPins.GPIO_PinConfig.GPIO_PinSpeed =
	GPIO_SPEED_FAST;

	USARTPins.GPIO_PinConfig.GPIO_PinOPType =
	GPIO_OP_TYPE_PP;

	USARTPins.GPIO_PinConfig.GPIO_PinPuPdControl =
	GPIO_PIN_PU;

	/* TX -> PA2 */
	USARTPins.GPIO_PinConfig.GPIO_PinNumber = 2;
	GPIO_Init(&USARTPins);

	/* RX -> PA3 */
	USARTPins.GPIO_PinConfig.GPIO_PinNumber = 3;
	GPIO_Init(&USARTPins);
}

