void vTask1_write(void *params);
void vTask2_read(void *params);

// Global space for some variables
UART_HandleTypeDef huart2;
char user_msg[100] = { 0 };

// Queue handles
QueueHandle_t qTask1ToTask2 = NULL;
QueueHandle_t qTask2ToTask1 = NULL;

// Task handles
TaskHandle_t xTaskHandle1 = NULL;
TaskHandle_t xTaskHandle2 = NULL;

void printmsg(char *msg) {
	for (uint32_t i = 0; i < strlen(msg); i++) {
		HAL_UART_Transmit(&huart2, (uint8_t*) &msg[i], 1, 100);
	}
}

int main(void) {

	HAL_Init();
	SystemClock_Config();

	prvSetupHardware();

	sprintf(user_msg, "\r\nQueue Communication demo\n\r");
	printmsg(user_msg);

	qTask1ToTask2 = xQueueCreate(10, sizeof(char*));
	qTask2ToTask1 = xQueueCreate(10, sizeof(char*));

	if (qTask1ToTask2 != NULL) {
		// create tasks
		xTaskCreate(vTask1_write, "TASK1-WRITE", 500, NULL, 1, &xTaskHandle1);

		xTaskCreate(vTask2_read, "TASK2-READ", 500, NULL, 3, &xTaskHandle2);

		vTaskStartScheduler();
	} else {
		sprintf(user_msg, "Queue creation failed\n\r");
		printmsg(user_msg);
	}

	while (1) {
		/* USER CODE END WHILE */

		/* USER CODE BEGIN 3 */
	}
	/* USER CODE END 3 */
}

void vTask1_write(void *params) {
	char *message = "Hello this is Task-1\r\n";

	char *buffer;

	while (1) {
		printmsg("Task1 sent message\r\n");

		xQueueSend(qTask1ToTask2, &message, portMAX_DELAY);

		//xQueueReceive(qTask2ToTask1,
		//&buffer,
		//portMAX_DELAY);

//		printmsg("Task1 received: ");
//
//		printmsg(buffer);

		taskYIELD();

		vTaskDelay(pdMS_TO_TICKS(1000));
	}
}

void vTask2_read(void *params) {
	char *buffer;

	char *reply = "Hello Task-1, this is Task-2\r\n";

	while (1) {
		xQueueReceive(qTask1ToTask2, &buffer,
		portMAX_DELAY);

		printmsg("Task2 received: ");

		printmsg(buffer);

		xQueueSend(qTask2ToTask1, &reply, portMAX_DELAY);

		vTaskDelay(pdMS_TO_TICKS(100));
	}
}
void rtos_delay(uint32_t delay_in_ms) {
	uint32_t current_tick_count = xTaskGetTickCount();

	uint32_t delay_in_ticks = (delay_in_ms * configTICK_RATE_HZ) / 1000;

	while (xTaskGetTickCount() < (current_tick_count + delay_in_ticks))
		;
}

static void prvSetupUart(void) {
	// enable the uart2 peripheral clock
	__HAL_RCC_GPIOA_CLK_ENABLE();

	//PA2 is UART2_TX, PA3 is UART_RX
	huart2.Instance = USART2;
	huart2.Init.BaudRate = 115200;
	huart2.Init.WordLength = UART_WORDLENGTH_8B;
	huart2.Init.StopBits = UART_STOPBITS_1;
	huart2.Init.Parity = UART_PARITY_NONE;
	huart2.Init.Mode = UART_MODE_TX_RX;
	huart2.Init.HwFlowCtl = UART_HWCONTROL_NONE;
	huart2.Init.OverSampling = UART_OVERSAMPLING_16;

	HAL_NVIC_EnableIRQ(USART2_IRQn);
	HAL_NVIC_SetPriority(USART2_IRQn, 5, 0);

	HAL_UART_Init(&huart2);
}

static void prvSetupHardware(void) {
	// setup UART
	prvSetupUart();
}

