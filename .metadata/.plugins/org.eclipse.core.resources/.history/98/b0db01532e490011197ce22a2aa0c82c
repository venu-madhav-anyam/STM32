#include <stdint.h>
#include <stdio.h>

/* Debug Exception and Monitor Control Register */
#define DEMCR      (*(volatile uint32_t*)0xE000EDFCU)

/* ITM Registers */
#define ITM_STIM0  (*(volatile uint32_t*)0xE0000000U)
#define ITM_TER    (*(volatile uint32_t*)0xE0000E00U)
#define ITM_TCR    (*(volatile uint32_t*)0xE0000E80U)

/* Bit */
#define DEMCR_TRCENA   (1 << 24)

/* Send one character over SWO */
void ITM_SendChar(uint8_t ch) {
	if ((DEMCR & DEMCR_TRCENA) && (ITM_TCR & 1) && (ITM_TER & 1)) {
		while (ITM_STIM0 == 0)
			;

		ITM_STIM0 = ch;
	}
}

/* printf redirection */
int __io_putchar(int ch) {
	ITM_SendChar(ch);
	return ch;
}
