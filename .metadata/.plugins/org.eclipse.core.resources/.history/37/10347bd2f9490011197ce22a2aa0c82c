#include "stm32l476xx_i2c.h"

void delay_ms(uint32_t time) {
	for (uint32_t i = 0; i < time * 4000; i++) {
		__asm("nop");
	}
}

void I2C_PeriClockControl(I2C_TypeDef *pI2Cx, uint8_t EnOrDi) {
	if (EnOrDi == ENABLE) {
		if (pI2Cx == I2C1) {
			I2C1_CLK_ENABLE();
		} else if (pI2Cx == I2C2) {
			I2C2_CLK_ENABLE();
		} else if (pI2Cx == I2C3) {
			I2C3_CLK_ENABLE();
		}
	} else {
		// disable later if needed
	}
}

void I2C_Init(I2C_Handle_t *pI2CHandle) {
	I2C_PeriClockControl(pI2CHandle->pI2Cx, ENABLE);

	/* Disable peripheral */
	pI2CHandle->pI2Cx->CR1 &= ~(1 << 0);

	/*
	 * TIMINGR value for:
	 * SYSCLK = 4MHz
	 * I2C = 100kHz
	 */
	pI2CHandle->pI2Cx->TIMINGR = 0x00303D5B;

	/* Enable peripheral */
	pI2CHandle->pI2Cx->CR1 |= (1 << 0);
}

void I2C_MasterSendData(I2C_Handle_t *pI2CHandle,
                        uint8_t *pTxBuffer,
                        uint32_t Len,
                        uint8_t SlaveAddr)
{
    /* Clear flags */
    pI2CHandle->pI2Cx->ICR |=
            (1 << I2C_ICR_STOPCF_Pos) |
            (1 << I2C_ICR_NACKCF_Pos);

    /* Clear CR2 */
    pI2CHandle->pI2Cx->CR2 = 0;

    /* Slave address */
    pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

    /* Number of bytes */
    pI2CHandle->pI2Cx->CR2 |=
            (Len << I2C_CR2_NBYTES_Pos);

    /* AUTOEND */
    pI2CHandle->pI2Cx->CR2 |=
            (1 << I2C_CR2_AUTOEND_Pos);

    /* PRELOAD FIRST BYTE */
    pI2CHandle->pI2Cx->TXDR = *pTxBuffer;

    pTxBuffer++;
    Len--;

    /* START */
    pI2CHandle->pI2Cx->CR2 |=
            (1 << I2C_CR2_START_Pos);

    while (Len > 0)
    {
        while (!(pI2CHandle->pI2Cx->ISR &
                I2C_ISR_TXIS))
        {
            if (pI2CHandle->pI2Cx->ISR &
                I2C_ISR_NACKF)
            {
                return;
            }
        }

        pI2CHandle->pI2Cx->TXDR = *pTxBuffer;

        pTxBuffer++;
        Len--;
    }

    while (!(pI2CHandle->pI2Cx->ISR &
            I2C_ISR_STOPF));

    /* Clear STOP */
    pI2CHandle->pI2Cx->ICR |=
            (1 << I2C_ICR_STOPCF_Pos);
}

void I2C_MasterReceiveData(I2C_Handle_t *pI2CHandle, uint8_t *pRxBuffer,
		uint32_t Len, uint8_t SlaveAddr) {
	/* Clear CR2 */
	pI2CHandle->pI2Cx->CR2 = 0;

	/* Slave address */
	pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

	/* Read operation */
	pI2CHandle->pI2Cx->CR2 |= (1 << 10);

	/* Number of bytes */
	pI2CHandle->pI2Cx->CR2 |= (Len << 16);

	/* AUTOEND */
	pI2CHandle->pI2Cx->CR2 |= (1 << 25);

	/* START */
	pI2CHandle->pI2Cx->CR2 |= (1 << 13);

	while (Len > 0) {
		uint32_t timeout = 100000;

		/* Wait until RXNE */
		while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_RXNE)) {
			/* NACK */
			if (pI2CHandle->pI2Cx->ISR & I2C_ISR_NACKF) {
				return;
			}

			/* Timeout */
			if (--timeout == 0) {
				return;
			}
		}

		/* Read data */
		*pRxBuffer = pI2CHandle->pI2Cx->RXDR;

		pRxBuffer++;
		Len--;
	}

	/* Wait for STOP */
	while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_STOPF)) {
		;
	}

	/* Clear STOP flag */
	pI2CHandle->pI2Cx->ICR |= (1 << 5);
}

void I2C_ScanBus(I2C_Handle_t *pI2CHandle) {
	//uint8_t dummy = 0;

	//printf("Scanning I2C Bus...\r\n");

	for (uint8_t addr = 1; addr < 128; addr++) {
		/* Clear CR2 */
		pI2CHandle->pI2Cx->CR2 = 0;

		/*
		 * Slave address
		 * NBYTES = 1
		 */
		pI2CHandle->pI2Cx->CR2 |= (addr << 1);
		pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_NBYTES_Pos);

		/* AUTOEND */
		pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_AUTOEND_Pos);

		/* START */
		pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

		uint32_t timeout = 10000;

		while (!(pI2CHandle->pI2Cx->ISR
				& ((1 << I2C_ISR_STOPF_Pos) | (1 << I2C_ISR_NACKF_Pos)))) {
			if (--timeout == 0)
				break;
		}

		/* Device responded */
		if (!(pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_NACKF_Pos))) {
			//printf("Device Found at 0x%X\r\n", addr);
		}

		/* Clear STOP */
		if (pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_STOPF_Pos)) {
			pI2CHandle->pI2Cx->ICR |= (1 << I2C_ICR_STOPCF_Pos);
		}

		/* Clear NACK */
		if (pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_NACKF_Pos)) {
			pI2CHandle->pI2Cx->ICR |= (1 << I2C_ICR_NACKCF_Pos);
		}

		delay_ms(2);
	}

	//printf("Scan Complete\r\n");
}

void I2C_MasterWriteRead(I2C_Handle_t *pI2CHandle,
                         uint8_t SlaveAddr,
                         uint8_t *pTxBuffer,
                         uint32_t TxLen,
                         uint8_t *pRxBuffer,
                         uint32_t RxLen)
{
    /* ---------- WRITE PHASE ---------- */

    pI2CHandle->pI2Cx->CR2 = 0;

    pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

    pI2CHandle->pI2Cx->CR2 |= (TxLen << 16);

    /* START */
    pI2CHandle->pI2Cx->CR2 |= (1 << 13);

    while (TxLen > 0)
    {
        while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_TXIS));

        pI2CHandle->pI2Cx->TXDR = *pTxBuffer;

        pTxBuffer++;
        TxLen--;
    }

    /* Wait for transfer complete */
    while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_TC));

    /* ---------- READ PHASE ---------- */

    pI2CHandle->pI2Cx->CR2 = 0;

    pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

    /* READ */
    pI2CHandle->pI2Cx->CR2 |= (1 << 10);

    pI2CHandle->pI2Cx->CR2 |= (RxLen << 16);

    /* AUTOEND */
    pI2CHandle->pI2Cx->CR2 |= (1 << 25);

    /* REPEATED START */
    pI2CHandle->pI2Cx->CR2 |= (1 << 13);

    while (RxLen > 0)
    {
        while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_RXNE));

        *pRxBuffer = pI2CHandle->pI2Cx->RXDR;

        pRxBuffer++;
        RxLen--;
    }

    while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_STOPF));

    /* Clear STOP */
    pI2CHandle->pI2Cx->ICR |= (1 << 5);
}
