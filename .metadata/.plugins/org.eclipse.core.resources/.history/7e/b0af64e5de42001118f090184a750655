void RTC_SetDateTime(void) {
	RTC_TimeTypeDef sTime = { 0 };
	RTC_DateTypeDef sDate = { 0 };

	/* -------- SET TIME -------- */
	sTime.Hours = 12;
	sTime.Minutes = 30;
	sTime.Seconds = 0;
	sTime.TimeFormat = RTC_HOURFORMAT12_AM;

	HAL_RTC_SetTime(&rtchand, &sTime, RTC_FORMAT_BIN);

	/* -------- SET DATE -------- */
	sDate.WeekDay = RTC_WEEKDAY_MONDAY;
	sDate.Month = RTC_MONTH_JANUARY;
	sDate.Date = 1;
	sDate.Year = 25;   // 2025

	HAL_RTC_SetDate(&rtchand, &sDate, RTC_FORMAT_BIN);

	HAL_RTCEx_BKUPWrite(&rtchand, RTC_BKP_DR0, BKP_FLAG);
}

void RTC_GetDateTime(char *time_buf, char *date_buf) {
	RTC_TimeTypeDef gTime;
	RTC_DateTypeDef gDate;

	HAL_RTC_GetTime(&rtchand, &gTime, RTC_FORMAT_BIN);
	HAL_RTC_GetDate(&rtchand, &gDate, RTC_FORMAT_BIN);

	// Store formatted strings
	sprintf(time_buf, "Time: %02d:%02d:%02d", gTime.Hours, gTime.Minutes,
			gTime.Seconds);

	sprintf(date_buf, "Date: %02d-%02d-20%02d", gDate.Date, gDate.Month,
			gDate.Year);
}

int main(void) {
	HAL_Init();
	SystemClock_Config();
	uart_init();

	__HAL_RTC_RESET_HANDLE_STATE(&rtchand);

	rtc_init();

	if (HAL_RTCEx_BKUPRead(&rtchand, RTC_BKP_DR0) != BKP_FLAG)
		RTC_SetDateTime();

	char time_str[20];
	char date_str[20];

	while (1) {

		printf("Tick = %lu\r\n", HAL_GetTick());
		RTC_GetDateTime(time_str, date_str);

		printf("%s\r\n", time_str);
		printf("%s\r\n", date_str);

		//HAL_Delay(1000);
	}
}
