#include "main.h"
#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include <stdio.h>
#include <string.h>

UART_HandleTypeDef huart2;

TaskHandle_t menuTaskHandle;
TaskHandle_t uartTaskHandle;
TaskHandle_t cmdHandleTask;
TaskHandle_t cmdProcessTask;

QueueHandle_t uart_write_queue;
QueueHandle_t command_queue;

uint8_t rx_byte;
char rx_buffer[50];
uint8_t rx_index = 0;

char uart_msg[64];

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
void menu_print_task(void *parameters);
void uart_write_task(void *parameters);
void cmd_handling_task(void *parameters);
void cmd_processing_task(void *parameters);

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
	BaseType_t xHigherPriorityTaskWoken = pdFALSE;

	if (huart->Instance == USART2) {
		//Store character
		rx_buffer[rx_index++] = rx_byte;

		//ENTER key received
		if (rx_byte == '\r' || rx_byte == '\n') {
			rx_buffer[rx_index - 1] = '\0';

			// Send command to queue
			xQueueSendFromISR(command_queue, rx_buffer,
					&xHigherPriorityTaskWoken);

			rx_index = 0;
		}

		// Restart interrupt reception
		HAL_UART_Receive_IT(&huart2, &rx_byte, 1);

		portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
	}
}

int main(void) {
	HAL_Init();

	SystemClock_Config();

	MX_GPIO_Init();

	MX_USART2_UART_Init();

	//Create Queues
	uart_write_queue = xQueueCreate(5, sizeof(uart_msg));
	command_queue = xQueueCreate(5, sizeof(uart_msg));

	if (!uart_write_queue && command_queue) {
		//Create Tasks
		xTaskCreate(menu_print_task, "Menu_Task", 512, NULL, 2,
				&menuTaskHandle);

		xTaskCreate(uart_write_task, "UART_Task", 512, NULL, 2,
				&uartTaskHandle);

		xTaskCreate(cmd_handling_task, "CMD_Handle", 512, NULL, 2,
				&cmdHandleTask);

		xTaskCreate(cmd_processing_task, "CMD_Process", 512, NULL, 2,
				&cmdProcessTask);

		HAL_UART_Receive_IT(&huart2, &rx_byte, 1);

		vTaskStartScheduler();
	} else
		printf("Queue Creation failed..!\r\n");

	while (1) {
	}
}

// Task 1 - Print menu into UART queue
void menu_print_task(void *parameters) {
	char menu[] = "\r\n"
			"==== MENU ====\r\n"
			"1 -> LED ON\r\n"
			"2 -> LED OFF\r\n"
			"3 -> LED TOGGLE\r\n";

	while (1) {
		xQueueSend(uart_write_queue, &menu, portMAX_DELAY);

		vTaskDelay(pdMS_TO_TICKS(5000));
	}
}

// Task 2 - UART writer task
void uart_write_task(void *parameters) {
	char msg[64];

	while (1) {
		if (xQueueReceive(uart_write_queue, msg, portMAX_DELAY) == pdPASS) {
			HAL_UART_Transmit(&huart2, (uint8_t*) msg, strlen(msg),
			HAL_MAX_DELAY);
		}
	}
}

// Task 3 - Simulate UART command reception
void cmd_handling_task(void *parameters) {
	char cmd[64];

	while (1) {
		/*
		 * Example:
		 * Button press generates command
		 */

		if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_13) == GPIO_PIN_RESET) {
			strcpy(cmd, "TOGGLE");

			xQueueSend(command_queue, &cmd, portMAX_DELAY);

			vTaskDelay(pdMS_TO_TICKS(300));

			while (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_13) == GPIO_PIN_RESET) {
				vTaskDelay(pdMS_TO_TICKS(10));
			}
		}

		vTaskDelay(pdMS_TO_TICKS(10));
	}
}
void cmd_handling_task(void *parameters) {
	char cmd[50];

	while (1) {
		if (xQueueReceive(command_queue, cmd, portMAX_DELAY) == pdPASS) {
			if (strcmp(cmd, "on") == 0) {
				HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);

				char msg[] = "LED ON\r\n";

				xQueueSend(uart_write_queue, msg, portMAX_DELAY);
			} else if (strcmp(cmd, "off") == 0) {
				HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);

				char msg[] = "LED OFF\r\n";

				xQueueSend(uart_write_queue, msg, portMAX_DELAY);
			} else if (strcmp(cmd, "toggle") == 0) {
				HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);

				char msg[] = "LED TOGGLED\r\n";

				xQueueSend(uart_write_queue, msg, portMAX_DELAY);
			} else {
				char msg[] = "INVALID COMMAND\r\n";

				xQueueSend(uart_write_queue, msg, portMAX_DELAY);
			}
		}
	}
}

// Task 4 - Process command
void cmd_processing_task(void *parameters) {
	char cmd[64];

	while (1) {
		if (xQueueReceive(command_queue, &cmd, portMAX_DELAY) == pdPASS) {
			if (strcmp(cmd, "TOGGLE") == 0) {
				HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);

				strcpy(uart_msg, "LED TOGGLED\r\n");

				xQueueSend(uart_write_queue, &uart_msg, portMAX_DELAY);
			}
		}
	}
}

