#include "main.h"
#include <stdio.h>

/* -------- HANDLES -------- */
I2C_HandleTypeDef hi2c2;
UART_HandleTypeDef huart2;

/* -------- PRINTF -------- */
int _write(int file, char *ptr, int len) {
	HAL_UART_Transmit(&huart2, (uint8_t*) ptr, len, 100);
	return len;
}

/* -------- GLOBAL I2C BUFFERS -------- */
uint8_t tx_buf[1];
uint8_t rx_buf[2];
volatile uint8_t i2c_state = 0;

/* -------- OPT3001 -------- */
#define OPT3001_ADDR        (0x47 << 1)
#define OPT3001_CONFIG_REG  0x01
#define OPT3001_RESULT_REG  0x00

/* -------- FUNCTION PROTOTYPES -------- */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_I2C2_Init(void);

/* -------- OPT3001 INIT -------- */
void OPT3001_Init(void) {
	uint8_t buf[3];

	buf[0] = OPT3001_CONFIG_REG;
	buf[1] = 0xC6;   // continuous mode
	buf[2] = 0x10;

	HAL_I2C_Master_Transmit(&hi2c2, OPT3001_ADDR, buf, 3, 100);
}

/* -------- START INTERRUPT READ -------- */
void OPT3001_StartRead(void) {
	tx_buf[0] = OPT3001_RESULT_REG;

	i2c_state = 1;

	HAL_I2C_Master_Transmit_IT(&hi2c2, OPT3001_ADDR, tx_buf, 1);
}

/* -------- CALLBACKS -------- */
void HAL_I2C_MasterTxCpltCallback(I2C_HandleTypeDef *hi2c) {
	if (hi2c->Instance == I2C2 && i2c_state == 1) {
		i2c_state = 2;
		HAL_I2C_Master_Receive_IT(&hi2c2, OPT3001_ADDR, rx_buf, 2);
	}
}

int lux;

void HAL_I2C_MasterRxCpltCallback(I2C_HandleTypeDef *hi2c) {
	if (hi2c->Instance == I2C2 && i2c_state == 2) {
		i2c_state = 0;

		uint16_t raw = (rx_buf[0] << 8) | rx_buf[1];

		uint16_t exp = (raw >> 12) & 0x0F;
		uint16_t mant = raw & 0x0FFF;

		lux = 0.01f * (1 << exp) * mant;

		printf("Light =  %.2f lux\r\n", lux);
	}
}

/* -------- IRQ HANDLERS -------- */
void I2C2_EV_IRQHandler(void) {
	HAL_I2C_EV_IRQHandler(&hi2c2);
}

void I2C2_ER_IRQHandler(void) {
	HAL_I2C_ER_IRQHandler(&hi2c2);
}

/* -------- MAIN -------- */
int main(void) {
	HAL_Init();
	SystemClock_Config();

	MX_GPIO_Init();
	MX_USART2_UART_Init();
	MX_I2C2_Init();


	OPT3001_Init();
	HAL_Delay(800);

	while (1) {
		OPT3001_StartRead();   // trigger interrupt
		HAL_Delay(500);
	}
}

/* -------- I2C INIT -------- */
static void MX_I2C2_Init(void) {
	hi2c2.Instance = I2C2;
	hi2c2.Init.Timing = 0x10D19CE4;
	hi2c2.Init.OwnAddress1 = 0;
	hi2c2.Init.AddressingMode = I2C_ADDRESSINGMODE_7BIT;
	hi2c2.Init.DualAddressMode = I2C_DUALADDRESS_DISABLE;
	hi2c2.Init.OwnAddress2 = 0;
	hi2c2.Init.OwnAddress2Masks = I2C_OA2_NOMASK;
	hi2c2.Init.GeneralCallMode = I2C_GENERALCALL_DISABLE;
	hi2c2.Init.NoStretchMode = I2C_NOSTRETCH_DISABLE;

	HAL_I2C_Init(&hi2c2);

	HAL_I2CEx_ConfigAnalogFilter(&hi2c2, I2C_ANALOGFILTER_ENABLE);
	HAL_I2CEx_ConfigDigitalFilter(&hi2c2, 0);

	// 🔥 ENABLE INTERRUPTS
	HAL_NVIC_SetPriority(I2C2_EV_IRQn, 0, 0);
	HAL_NVIC_EnableIRQ(I2C2_EV_IRQn);

	HAL_NVIC_SetPriority(I2C2_ER_IRQn, 0, 0);
	HAL_NVIC_EnableIRQ(I2C2_ER_IRQn);
}

void Error_Handler(void) {

	__disable_irq();
	while (1) {
	}
}

