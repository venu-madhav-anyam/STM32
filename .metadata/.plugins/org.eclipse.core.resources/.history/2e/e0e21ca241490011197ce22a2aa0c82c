#include "stm32l476xx_i2c.h"

void I2C_MasterSendData(I2C_Handle_t *pI2CHandle,
                        uint8_t *pTxBuffer,
                        uint32_t Len,
                        uint8_t SlaveAddr)
{
    /* Slave address */
    pI2CHandle->pI2Cx->CR2 =
            (SlaveAddr << 1) |
            (Len << 16);

    /* START */
    pI2CHandle->pI2Cx->CR2 |= (1 << 13);

    while (Len > 0)
    {
        while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_TXIS));

        pI2CHandle->pI2Cx->TXDR = *pTxBuffer;

        pTxBuffer++;
        Len--;
    }

    while (!(pI2CHandle->pI2Cx->ISR & I2C_ISR_TC));

    /* STOP */
    pI2CHandle->pI2Cx->CR2 |= (1 << 14);
}
