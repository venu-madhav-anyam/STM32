/* -------- SENSOR INIT -------- */
void Ultrasonic_Init(void) {
	GPIO_Handle_t trig, echo;

	/* TRIG → OUTPUT */
	trig.pGPIOx = GPIOA;
	trig.GPIO_PinConfig.GPIO_PinNumber = TRIG_PIN;
	trig.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUTPUT;
	trig.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_LOW;
	trig.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
	trig.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;

	GPIO_Init(&trig);

	/* ECHO → INPUT */
	echo.pGPIOx = GPIOA;
	echo.GPIO_PinConfig.GPIO_PinNumber = ECHO_PIN;
	echo.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_INPUT;
	echo.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_LOW;
	echo.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;

	GPIO_Init(&echo);
}

/* -------- READ DISTANCE -------- */
uint32_t Ultrasonic_Read(void) {
	uint32_t time = 0;
	uint32_t timeout;

	/* Send trigger pulse */
	GPIO_WriteToOutputPin(GPIOA, TRIG_PIN, 0);
	delay_us(2);

	GPIO_WriteToOutputPin(GPIOA, TRIG_PIN, 1);
	delay_us(10);

	GPIO_WriteToOutputPin(GPIOA, TRIG_PIN, 0);

	/* Wait for ECHO HIGH */
	timeout = 30000;

	while (GPIO_ReadFromInputPin(GPIOA, ECHO_PIN) == 0) {
		if (--timeout == 0)
			return 0;
	}

	/* Measure HIGH duration */
	//timeout = 30000;
	while (GPIO_ReadFromInputPin(GPIOA, ECHO_PIN) == 1) {
		time++;
		__asm("nop");

	}

	return time;
}

SPI_Handle_t SPI1Handle;

void SPI_GPIO_Init(void) {
	GPIO_Handle_t spiPins;

	memset(&spiPins, 0, sizeof(spiPins));

	spiPins.pGPIOx = GPIOA;

	spiPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_ALTFN;
	spiPins.GPIO_PinConfig.GPIO_PinAltFunMode = 5; // AF5 (SPI1)
	spiPins.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;
	spiPins.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
	spiPins.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;

	// SCK
	spiPins.GPIO_PinConfig.GPIO_PinNumber = 5;
	GPIO_Init(&spiPins);

	// MISO
	spiPins.GPIO_PinConfig.GPIO_PinNumber = 6;
	GPIO_Init(&spiPins);

	// MOSI
	spiPins.GPIO_PinConfig.GPIO_PinNumber = 7;
	GPIO_Init(&spiPins);

	// CS (manual)
	spiPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUTPUT;
	spiPins.GPIO_PinConfig.GPIO_PinNumber = 4;
	GPIO_Init(&spiPins);

	GPIO_WriteToOutputPin(GPIOA, 4, 1); // CS HIGH
}

float debug_write;
float debug_read;
uint8_t read_buf[4];
uint8_t buf[4];

int dist;

int main(void) {
	SPI_GPIO_Init();
	W25Q_Init();

	SPI1Handle.pSPIx = SPI1;

	SPI1Handle.SPI_Config.DeviceMode = SPI_DEVICE_MODE_MASTER;
	SPI1Handle.SPI_Config.BusConfig = SPI_BUS_CONFIG_FD;
	SPI1Handle.SPI_Config.SclkSpeed = SPI_SCLK_SPEED_DIV16;
	SPI1Handle.SPI_Config.DFF = SPI_DFF_8BITS;
	SPI1Handle.SPI_Config.CPOL = SPI_CPOL_LOW;
	SPI1Handle.SPI_Config.CPHA = SPI_CPHA_LOW;
	SPI1Handle.SPI_Config.SSM = SPI_SSM_EN;

	SPI_Init(&SPI1Handle);

	Ultrasonic_Init();

	uint32_t addr = 0;

	while (1) {
		uint32_t time = Ultrasonic_Read();

		dist = time / 38;

		memcpy(buf, &dist, 4);

		W25Q_Write(addr, buf, 4);

		delay_ms(10);

		W25Q_Read(addr, read_buf, 4);

		memcpy(&debug_read, read_buf, 4);

		debug_write = dist;
		//printf("Dist = %f\r\n",dist);
		//printf("Data = %f\r\n",debug_read);


		addr += 4;

		if (addr >= 40)
			addr = 0;

		delay_ms(100);
	}
}
