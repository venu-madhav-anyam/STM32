#include "stm32l476xx.h"
#include "stm32l476xx_gpio.h"
#include "stm32l476xx_i2c.h"
#include <stdio.h>

I2C_Handle_t I2CHandle;

/* ========================================================= */
/*                        DELAY                              */
/* ========================================================= */

void delay_ms(uint32_t time) {
	for (uint32_t i = 0; i < time * 4000; i++) {
		__asm("nop");
	}
}

/* ========================================================= */
/*                    I2C2 GPIO INIT                         */
/* ========================================================= */

void I2C_GPIO_Init(void) {
	GPIO_Handle_t I2CPins;

	I2CPins.pGPIOx = GPIOB;

	I2CPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_ALTFN;
	I2CPins.GPIO_PinConfig.GPIO_PinAltFunMode = 4;
	I2CPins.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_OD;
	I2CPins.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_PIN_PU;
	I2CPins.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;

	/* PB10 -> SCL */
	I2CPins.GPIO_PinConfig.GPIO_PinNumber = 10;
	GPIO_Init(&I2CPins);

	/* PB11 -> SDA */
	I2CPins.GPIO_PinConfig.GPIO_PinNumber = 11;
	GPIO_Init(&I2CPins);
}

/* ========================================================= */
/*                     I2C BUS SCAN                          */
/* ========================================================= */

void I2C_ScanBus(I2C_Handle_t *pI2CHandle) {
	printf("Scanning I2C Bus...\r\n");

	for (uint8_t addr = 1; addr < 128; addr++) {
		/* Clear CR2 */
		pI2CHandle->pI2Cx->CR2 = 0;

		/* Slave address */
		pI2CHandle->pI2Cx->CR2 |= (addr << 1);

		/* AUTOEND */
		pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_AUTOEND_Pos);

		/* START */
		pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

		uint32_t timeout = 10000;

		while (!(pI2CHandle->pI2Cx->ISR
				& ((1 << I2C_ISR_STOPF_Pos) | (1 << I2C_ISR_NACKF_Pos)))) {
			if (--timeout == 0)
				break;
		}

		/* Device found */
		if (!(pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_NACKF_Pos))) {
			printf("Device Found at 0x%X\r\n", addr);
		}

		/* Clear STOP flag */
		if (pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_STOPF_Pos)) {
			pI2CHandle->pI2Cx->ICR |= (1 << I2C_ICR_STOPCF_Pos);
		}

		/* Clear NACK flag */
		if (pI2CHandle->pI2Cx->ISR & (1 << I2C_ISR_NACKF_Pos)) {
			pI2CHandle->pI2Cx->ICR |= (1 << I2C_ICR_NACKCF_Pos);
		}

		delay_ms(2);
	}

	printf("Scan Complete\r\n");
}

/* ========================================================= */
/*                         MAIN                              */
/* ========================================================= */

int main(void) {
	/* GPIO Init */
	I2C_GPIO_Init();

	/* I2C2 Config */
	I2CHandle.pI2Cx = I2C2;

	I2CHandle.I2C_Config.SCLSpeed = I2C_SCL_SPEED_SM;
	I2CHandle.I2C_Config.DeviceAddress = 0x61;
	I2CHandle.I2C_Config.ACKControl = I2C_ACK_ENABLE;

	/* I2C Init */
	I2C_Init(&I2CHandle);

	while (1) {
		I2C_ScanBus(&I2CHandle);

		delay_ms(3000);
	}
}
