#include "main.h"
#include "FreeRTOS.h"
#include "task.h"
#include <stdio.h>

TaskHandle_t xTaskHandle1;
TaskHandle_t xTaskHandle2;

UART_HandleTypeDef huart2;

#define TRUE	1
#define FALSE	0

uint8_t BUTTON_PRESS = TRUE;

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
void vtask_handler1(void *parameters);
void vtask_handler2(void *parameters);

int main(void) {
	HAL_Init();

	SystemClock_Config();

	MX_GPIO_Init();
	MX_USART2_UART_Init();

	xTaskCreate(vtask_handler1, "Task-1", configMINIMAL_STACK_SIZE, NULL, 2,
			&xTaskHandle1);
	xTaskCreate(vtask_handler2, "Task-2", configMINIMAL_STACK_SIZE, NULL, 2,
			&xTaskHandle2);

	vTaskStartScheduler();

	while (1) {
	}
}

void vtask_handler1(void *parameters) {
	while (1) {

		vTaskDelay(pdMS_TO_TICKS(1000));
		HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);

	}
}

void vtask_handler2(void *parameters) {
	while (1) {
		if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_13) == GPIO_PIN_SET) {
			vTaskDelay(pdMS_TO_TICKS(200));
			HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
		} else {
			printf("Task 2 is Getting deleted.\r\n");
			vTaskDelete(NULL);
		}

		vTaskDelay(pdMS_TO_TICKS(50));
	}
}

