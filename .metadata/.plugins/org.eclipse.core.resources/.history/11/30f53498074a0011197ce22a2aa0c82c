#include "opt3001.h"

//WRITE REGISTER
void OPT3001_WriteReg(I2C_Handle_t *pI2CHandle, uint8_t reg, uint16_t value) {
	uint8_t data[3];

	data[0] = reg;

	data[1] = (value >> 8) & 0xFF;
	data[2] = value & 0xFF;

	I2C_MasterSendData(pI2CHandle, data, 3,
	OPT3001_ADDR);
}

void I2C_MasterWriteRead(I2C_Handle_t *pI2CHandle, uint8_t SlaveAddr,
		uint8_t *pTxBuffer, uint32_t TxLen, uint8_t *pRxBuffer, uint32_t RxLen) {
	uint32_t timeout;

	/* Clear flags */
	pI2CHandle->pI2Cx->ICR |=
	I2C_ICR_STOPCF |
	I2C_ICR_NACKCF;

	/* ---------------- WRITE PHASE ---------------- */

	pI2CHandle->pI2Cx->CR2 = 0;

	pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

	pI2CHandle->pI2Cx->CR2 |= (TxLen << I2C_CR2_NBYTES_Pos);

	/* START */
	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

	while (TxLen > 0) {
		timeout = 100000;

		while (!(pI2CHandle->pI2Cx->ISR &
		I2C_ISR_TXIS)) {
			if (--timeout == 0)
				return;
		}

		pI2CHandle->pI2Cx->TXDR = *pTxBuffer;

		pTxBuffer++;
		TxLen--;
	}

	/* Wait TC */
	while (!(pI2CHandle->pI2Cx->ISR &
	I2C_ISR_TC))
		;

	/* ---------------- READ PHASE ---------------- */

	pI2CHandle->pI2Cx->CR2 = 0;

	pI2CHandle->pI2Cx->CR2 |= (SlaveAddr << 1);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_RD_WRN_Pos);

	pI2CHandle->pI2Cx->CR2 |= (RxLen << I2C_CR2_NBYTES_Pos);

	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_AUTOEND_Pos);

	/* RESTART */
	pI2CHandle->pI2Cx->CR2 |= (1 << I2C_CR2_START_Pos);

	while (RxLen > 0) {
		timeout = 100000;

		while (!(pI2CHandle->pI2Cx->ISR &
		I2C_ISR_RXNE)) {
			if (--timeout == 0)
				return;
		}

		*pRxBuffer = pI2CHandle->pI2Cx->RXDR;

		pRxBuffer++;
		RxLen--;
	}

	while (!(pI2CHandle->pI2Cx->ISR &
	I2C_ISR_STOPF))
		;

	pI2CHandle->pI2Cx->ICR |=
	I2C_ICR_STOPCF;
}

//READ REGISTER
uint16_t OPT3001_ReadReg(I2C_Handle_t *pI2CHandle, uint8_t reg) {
	uint8_t rx[2];

	I2C_MasterWriteRead(pI2CHandle,
	OPT3001_ADDR, &reg, 1, rx, 2);

	return ((rx[0] << 8) | rx[1]);
}

//SENSOR INIT
void OPT3001_Init(I2C_Handle_t *pI2CHandle) {

	OPT3001_WriteReg(pI2CHandle,
	OPT3001_REG_CONFIG, 0xC410);
}

//READ LUX
int OPT3001_ReadLux(I2C_Handle_t *pI2CHandle) {
	uint16_t raw = 0x0000;
	uint16_t exponent;
	uint16_t mantissa;

	raw = OPT3001_ReadReg(pI2CHandle,
	OPT3001_REG_RESULT);

	exponent = (raw >> 12) & 0x0F;

	mantissa = raw & 0x0FFF;
	int l = mantissa * (1 * (1UL << exponent));

	return (int) l;
}
