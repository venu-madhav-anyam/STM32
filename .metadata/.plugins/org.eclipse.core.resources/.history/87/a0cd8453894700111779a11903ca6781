#include <stdint.h>
#include "gpio.h"


int main(void)
{
    /* Enable GPIOA clock */
    GPIOA_EnableClock();

    /* Configure PA5 as output */
    GPIO_Init_Output(GPIOA, 5);

    while (1)
    {
        GPIO_TogglePin(GPIOA, 5);

        for (volatile int i = 0; i < 100000; i++); // delay
    }
}
