#include "stm32l476xx.h"
#include "stm32l476xx_gpio.h"
#include "stm32l476xx_spi.h"
#include "stm32l476xx_uart.h"
#include "w25qxx.h"
#include <stdio.h>
#include <string.h>

SPI_Handle_t SPI1Handle;
USART_Handle_t USART2Handle;

