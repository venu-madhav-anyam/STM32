#include "stm32l476xx.h"
#include "stm32l476xx_gpio.h"
#include "stm32l476xx_i2c.h"
#include "opt3001.h"
#include <stdio.h>

/* ==========================================================
 * ======================= GLOBALS ===========================
 * ========================================================== */

I2C_Handle_t I2C2Handle;

volatile uint8_t rxBuf[2];

volatile uint8_t dataReady = 0;

volatile uint16_t rawLux = 0;

volatile int lux = 0;

/* ==========================================================
 * ======================== DELAY ============================
 * ========================================================== */


/* ==========================================================
 * ===================== I2C GPIO INIT ======================
 * ========================================================== */

void I2C2_GPIO_Init(void) {
	GPIO_Handle_t I2CPins;

	I2CPins.pGPIOx = GPIOB;

	I2CPins.GPIO_PinConfig.GPIO_PinMode =
	GPIO_MODE_ALTFN;

	I2CPins.GPIO_PinConfig.GPIO_PinAltFunMode = 4;

	I2CPins.GPIO_PinConfig.GPIO_PinOPType =
	GPIO_OP_TYPE_OD;

	I2CPins.GPIO_PinConfig.GPIO_PinPuPdControl =
	GPIO_NO_PUPD;

	I2CPins.GPIO_PinConfig.GPIO_PinSpeed =
	GPIO_SPEED_FAST;

	/* PB10 -> SCL */
	I2CPins.GPIO_PinConfig.GPIO_PinNumber = 10;
	GPIO_Init(&I2CPins);

	/* PB11 -> SDA */
	I2CPins.GPIO_PinConfig.GPIO_PinNumber = 11;
	GPIO_Init(&I2CPins);
}

/* ==========================================================
 * ===================== I2C2 IRQ ===========================
 * ========================================================== */

void I2C2_EV_IRQHandler(void) {
	I2C_IRQHandling(&I2C2Handle);

	/* Transfer completed */
	if (I2C2Handle.TxRxState == I2C_READY) {
		dataReady = 1;
	}
}

/* ==========================================================
 * ========================= MAIN ============================
 * ========================================================== */

int main(void) {
	/* GPIO INIT */
	I2C2_GPIO_Init();

	/* ======================================================
	 * I2C CONFIG
	 * ====================================================== */

	I2C2Handle.pI2Cx = I2C2;

	I2C2Handle.I2C_Config.SCLSpeed =
	I2C_SCL_SPEED_SM;

	I2C2Handle.I2C_Config.DeviceAddress = 0x61;

	I2C2Handle.I2C_Config.ACKControl =
	I2C_ACK_ENABLE;

	I2C_Init(&I2C2Handle);

	/* ======================================================
	 * IRQ CONFIG
	 * ====================================================== */

	I2C_IRQConfig(IRQ_NO_I2C2_EV, 2,
	ENABLE);

	/* ======================================================
	 * OPT3001 CONFIG
	 * ====================================================== */

	OPT3001_WriteReg(&I2C2Handle,
	OPT3001_REG_CONFIG, 0xC410);

	delay_ms(100);

	/* ======================================================
	 * LOOP
	 * ====================================================== */

	while (1) {
		dataReady = 0;

		/* Start interrupt read */
		I2C_MasterReceiveDataIT(&I2C2Handle,
		OPT3001_ADDR,
		OPT3001_REG_RESULT, (uint8_t*) rxBuf, 2);

		/* Wait transfer complete */
		while (!dataReady)
			;

		/* Convert raw */
		rawLux = ((rxBuf[0] << 8) | rxBuf[1]);

		uint16_t exponent;
		uint16_t mantissa;

		exponent = (rawLux >> 12) & 0x0F;

		mantissa = rawLux & 0x0FFF;

		lux = mantissa * ((1 << exponent)/100);

		//printf("Lux = %.2f\r\n", lux);

		delay_ms(500);
	}
}
